# Environment Configuration
NODE_ENV=development
PORT=3000
DATABASE_URL="file:./dev.db"
LOG_LEVEL=info
API_VERSION=v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_TTL_HIGH=0
CACHE_TTL_MEDIUM=604800000  # 7 days in milliseconds
CACHE_TTL_LOW=259200000     # 3 days in milliseconds
CACHE_TTL_WHITELIST=2592000000  # 30 days in milliseconds
CACHE_TTL_FALLBACK=300000   # 5 minutes in milliseconds

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Risk Scoring
RISK_THRESHOLD_HIGH=70
RISK_THRESHOLD_MEDIUM=31
RISK_SCORE_MAX=100